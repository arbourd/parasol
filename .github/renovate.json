{
  "enabledManagers": ["custom.regex", "flux", "github-actions", "helm-values"],
  "flux": {
    "fileMatch": ["^cluster/.+\\.yaml$"]
  },
  "helm-values": {
    "fileMatch": ["^cluster/.+/helmrelease\\.yaml$"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["talconfig.yaml"],
      "matchStrings": [
        "kubernetesVersion: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["talconfig.yaml"],
      "matchStrings": [
        "talosVersion: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["talconfig.yaml"],
      "groupName": "talconfig"
    },
    {
      "matchPackageNames": ["ghcr.io/koush/scrypted"],
      "allowedVersions": "/^v\\d+\\.\\d*[13579]\\./"
    }
  ]
}
