#!/usr/bin/env zsh
setopt errexit nounset pipefail

local -a staged
staged=("${(@f)$(git diff --cached --name-only --diff-filter=ACM)}")

for file in $staged; do
  [[ $file != *.yaml ]] && continue

  if git show ":$file" | grep -q 'kind: Secret'; then
    if [[ $file != *.sops.yaml ]]; then
      print "ERROR: $file contains 'kind: Secret' but is not encrypted (.sops.yaml)"
      exit 1
    fi
    if ! git show ":$file" | grep -q '^sops:'; then
      print "ERROR: $file looks unencrypted — run: sops --encrypt --in-place $file"
      exit 1
    fi
  fi
done
