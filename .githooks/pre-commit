#!/usr/bin/env bash
set -euo pipefail

staged=()
while IFS= read -r file; do
  staged+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACM)

for file in "${staged[@]+"${staged[@]}"}"; do
  [[ $file != *.yaml ]] && continue

  if git show ":$file" | grep -q 'kind: Secret'; then
    if [[ $file != *.sops.yaml ]]; then
      echo "ERROR: $file contains 'kind: Secret' but is not encrypted (.sops.yaml)"
      exit 1
    fi
    if ! git show ":$file" | grep -q '^sops:'; then
      echo "ERROR: $file looks unencrypted — run: sops --encrypt --in-place $file"
      exit 1
    fi
  fi
done
